# --- Traefik / Domain Configuration ---
PROJECT_NAME=pactum_prod
FRONTEND_DOMAIN=pactum.local
BACKEND_DOMAIN=api.pactum.local

# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=strong_prod_password
POSTGRES_DB=pactum_prod_db

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=strong_prod_mq_password

# --- MinIO ---
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=strong_prod_minio_password

# --- JWT (Backend Security) ---
JWT_SECRET=super_secret_jwt_key_for_prod_only
JWT_EXPIRATION=1d
